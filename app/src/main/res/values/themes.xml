<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DanceTimer" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF121212</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Pure-black full-screen theme for the lock screen overlay activity.
         No action bar, no status bar, no navigation bar — maximises visible area
         and matches the AOD aesthetic (black background, white/green text). -->
    <style name="Theme.DanceTimer.LockScreen" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF000000</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>
    </style>
</resources>